# Copy to /etc/trello-to-table.env on the VM (or .env locally) and fill in.
# NEVER commit the real .env — only this .example file.

PORT=5566

# Password used to gate the API. Pick a long random string.
API_PASSWORD=change-me-to-a-long-random-string

# Google Maps Embed API key, restricted to your site's domain in Google Cloud Console.
GOOGLE_MAPS_KEY=your-google-maps-key-here

# Where the SQLite DB lives. On VM: /var/lib/trello-to-table
DATA_DIR=./data

# Directory containing index.html, app.js, etc. On VM: /opt/trello-to-table
STATIC_DIR=..
