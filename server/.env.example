# Copy to .env on the VM (or locally) and fill in.
# NEVER commit the real .env — only this .example file.

PORT=5566

# Password used to gate the API. Pick a long random string.
API_PASSWORD=change-me-to-a-long-random-string

# Google Maps Embed API key, restricted to your site's domain in Google Cloud Console.
GOOGLE_MAPS_KEY=your-google-maps-key-here

# MiniMax (https://platform.minimax.io) — used to extract clean place names
# from itinerary card titles. Leave empty to disable and fall back to regex.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
# Optional override:
# MINIMAX_ENDPOINT=https://api.minimax.io/v1/chat/completions
# LLM_TIMEOUT_MS=25000

# Where the SQLite DB lives. On VM: /var/lib/trello-to-table
DATA_DIR=./data

# Directory containing index.html, app.js, etc.
STATIC_DIR=..
