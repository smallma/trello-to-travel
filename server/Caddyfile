# /etc/caddy/Caddyfile
travel.taiwanno1.cc {
    encode zstd gzip
    # Cache static assets aggressively, never cache index.html
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.webp *.svg *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
    header /index.html Cache-Control "no-cache"

    # Reverse proxy everything to the Node app, which serves both /api/* and
    # the static frontend (Hono's serveStatic).
    reverse_proxy 127.0.0.1:5566
}
